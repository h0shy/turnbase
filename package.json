{
  "name": "turnbase",
  "version": "0.1.0",
  "description": "A verifiable interaction runtime for structured multi-party protocols",
  "type": "module",
  "bin": {
    "turnbase-mcp": "./dist/mcp.js"
  },
  "files": [
    "dist/",
    "public/",
    "src/",
    "tsconfig.json",
    "tsconfig.build.json",
    "smithery.yaml"
  ],
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "start": "tsx src/index.ts",
    "mcp": "tsx src/mcp.ts",
    "build": "tsc -p tsconfig.build.json",
    "prepublishOnly": "npm run build",
    "typecheck": "tsc --noEmit",
    "verify": "tsx scripts/verify.ts",
    "demo": "tsx examples/agents.ts"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.78.0",
    "@hono/node-server": "^1.13",
    "@hono/swagger-ui": "^0.6.0",
    "@modelcontextprotocol/sdk": "^1.27.1",
    "chess.js": "^1.3",
    "hono": "^4.6",
    "uuid": "^11.0"
  },
  "devDependencies": {
    "@types/node": "^22.0",
    "tsx": "^4.19",
    "typescript": "^5.7"
  }
}
